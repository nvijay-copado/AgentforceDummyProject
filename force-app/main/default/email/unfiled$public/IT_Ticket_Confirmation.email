<messaging:emailTemplate subject="IT Ticket Confirmation: {!relatedTo.Name}" recipientType="Contact" relatedToType="IT_Ticket__c">
<messaging:htmlEmailBody >
<html>
<body>
<p>Hello {!relatedTo.Employee_Name__c},</p>
<p>Your IT request <strong>{!relatedTo.Name}</strong> has been submitted successfully.</p>
<p><strong>Subject:</strong> {!relatedTo.Subject__c}<br/>
<strong>Priority:</strong> {!relatedTo.Priority__c}<br/>
<strong>Category:</strong> {!relatedTo.Category__c}<br/>
<strong>SLA Due Date:</strong> {!relatedTo.SLA_Due_Date__c}</p>
<p>Our team will respond within the expected SLA timeframe. You can reference your ticket using ID <strong>{!relatedTo.Name}</strong>.</p>
<p>Thank you,<br/>IT Help Desk</p>
</body>
</html>
</messaging:htmlEmailBody>
</messaging:emailTemplate>
